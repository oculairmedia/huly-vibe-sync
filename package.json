{
  "name": "vibesync",
  "version": "1.0.0",
  "description": "Project sync service with PM agent orchestration",
  "main": "index.js",
  "type": "module",
  "bin": {
    "vibesync": "src/cli.ts"
  },
  "scripts": {
    "start": "bun index.js",
    "start:node": "node index.js",
    "dev": "DRY_RUN=true SYNC_INTERVAL=0 bun index.js",
    "sync-once": "SYNC_INTERVAL=0 bun index.js",
    "build": "bun build --target=bun --outdir=dist index.js src/cli.ts",
    "build:binary": "bun scripts/build-binary.ts",
    "build:binary:windows": "bun scripts/build-binary.ts",
    "build:cli": "bun build --target=bun --outfile dist/vibesync-cli.js src/cli.ts",
    "temporal:worker": "bunx ts-node temporal/worker.ts",
    "temporal:build": "bunx tsc -p temporal/tsconfig.json",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage",
    "test:ui": "bunx vitest --ui",
    "test:unit": "bunx vitest run tests/unit",
    "test:integration": "bunx vitest run tests/integration",
    "test:temporal": "bunx vitest run tests/unit/temporal tests/unit/TemporalOrchestration.test.ts tests/unit/AgentProvisioning.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "bunx tsc -p tsconfig.json --noEmit",
    "type-check:runtime-js": "bunx tsc -p tsconfig.runtime-js.json --noEmit",
    "type-check:all": "bun run type-check && bun run type-check:runtime-js && bun run temporal:build",
    "manage": "node manage-agents.js",
    "agents": "node manage-agents.js list-agents",
    "migrate": "node migrate-agents-to-v1.js",
    "control-agent": "node create-control-agent.js",
    "compare-agents": "node tests/compare-agent-sources.js",
    "migrate-agents-md": "node migrate-agents-md.js",
    "migrate-agents-db": "node migrate-agents-to-db.js",
    "vibesync": "bun src/cli.ts"
  },
  "keywords": [
    "vibesync",
    "pm-agents",
    "sync",
    "mcp",
    "bidirectional-sync"
  ],
  "author": "Oculair Media",
  "license": "MIT",
  "dependencies": {
    "@letta-ai/letta-client": "^0.0.68665",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.14.1",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^9.2.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.5",
    "mysql2": "^3.20.0",
    "node-fetch": "^3.3.2",
    "p-debounce": "^5.1.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3",
    "undici": "^7.24.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "bun": ">=1.2.10",
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@temporalio/testing": "^1.14.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.0.6",
    "@vitest/ui": "^4.0.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "nock": "^14.0.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  }
}
